	top: 24px;
	left: -24px;
	width: 50%;
	height: 50%;
	z-index: -1;
}

	.photo-wrapper img {
		display: block;
		width: 100%;
		aspect-ratio: 4 / 4.6;
		object-fit: cover;
		background: #dedbd4;
	}

	.eyebrow {
		margin: 0 0 12px;
		color: #a63b31;
		font-size: 13px;
		font-weight: 700;
		letter-spacing: 0.17em;
		text-transform: uppercase;
