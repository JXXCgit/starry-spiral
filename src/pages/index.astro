		gap: 28px;
	}

	nav a {
		font-size: 15px;
	}

	nav a:hover,
	.links a:hover,
	.project-card a:hover,
	footer a:hover {
		color: #a63b31;
	}

	.hero {
		padding: 70px 0 35px;
		display: grid;
		grid-template-columns: minmax(280px, 0.8fr) minmax(300px, 1.2fr);
		gap: 90px;
		align-items: start;
