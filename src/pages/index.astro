<style>
	:global(*) {
		box-sizing: border-box;
	}

	:global(html) {
		scroll-behavior: smooth;
	}

	:global(body) {
		margin: 0;
		background: #f5f3ee;
		color: #171717;
		font-family: Arial, Helvetica, sans-serif;
		line-height: 1.7;
	}

	:global(a) {
		color: inherit;
		text-decoration: none;
	}

	.header,
	main,
	footer {
