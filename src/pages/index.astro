		margin: 0 auto;
	}

	.header {
		padding: 28px 0;
		display: flex;
		align-items: center;
		justify-content: space-between;
		border-bottom: 1px solid #d7d3cb;
	}

.logo {
	font-family: "Cormorant Garamond", Georgia, serif;
	font-size: 27px;
	font-weight: 600;
	letter-spacing: -0.02em;
}

	nav {
